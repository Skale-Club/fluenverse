# Core Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Site
# Optional: defaults to https://fluenverse.com in production metadata
NEXT_PUBLIC_SITE_URL=https://fluenverse.com
# Optional: emergency admin allowlist, comma-separated
ADMIN_FALLBACK_EMAILS=

# OpenAI
# Optional: only needed for /api/chat
OPENAI_API_KEY=

# Public assets
# Optional: defaults to landing-page
NEXT_PUBLIC_PUBLIC_ASSETS_BUCKET=landing-page
# Optional: override the full public assets base URL
# NEXT_PUBLIC_ASSET_BASE_URL=https://YOUR-PROJECT.supabase.co/storage/v1/object/public/landing-page
# Optional: script-only override for upload target bucket
# SUPABASE_PUBLIC_ASSETS_BUCKET=landing-page

# Go High Level
GHL_API_KEY=YOUR_GHL_API_KEY
GHL_LOCATION_ID=YOUR_GHL_LOCATION_ID
GHL_CALENDAR_ID=YOUR_GHL_CALENDAR_ID

# Twilio
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=YOUR_TWILIO_FROM_NUMBER
TWILIO_ENABLED=true
TWILIO_TO_NUMBERS=+5511999999999,+5511888888888

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Google Tag Manager / GA4
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook CAPI
# Optional: can also be managed via app_config in Supabase
FACEBOOK_ENABLED=false
FACEBOOK_DATASET_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_TEST_EVENT_CODE=
FACEBOOK_APP_ID=
